{
  "gates": [
    {
      "name": "typecheck",
      "command": "npx tsc --noEmit --pretty false",
      "weight": 30,
      "skip_if_missing": "tsconfig.json"
    },
    {
      "name": "lint",
      "command": "npx biome check .",
      "weight": 20,
      "skip_if_missing": "node_modules/.bin/biome"
    },
    {
      "name": "test",
      "command": "npx vitest run",
      "weight": 30,
      "skip_if_missing": "node_modules/.bin/vitest"
    },
    {
      "name": "coverage",
      "command": "$LOOPER_PKG_DIR/lib/check-coverage.sh",
      "weight": 20,
      "required": false
    }
  ],
  "checks": [
    {
      "name": "biome",
      "command": "npx biome check {file}",
      "fix": "npx biome check --write {file}",
      "pattern": "*.ts,*.tsx,*.js,*.jsx",
      "skip_if_missing": "node_modules/.bin/biome"
    },
    {
      "name": "typecheck",
      "command": "npx tsc --noEmit --pretty false",
      "pattern": "*.ts,*.tsx",
      "skip_if_missing": "tsconfig.json"
    }
  ]
}
